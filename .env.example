# Скопируйте этот файл в .env и укажите свой API-ключ
# cp .env.example .env

# === GigaChat (приоритет, если задан) ===
# Ключ: https://developers.sber.ru/studio
GIGACHAT_CREDENTIALS=your-gigachat-key
# GIGACHAT_MODEL=GigaChat
# Для разработки (без сертификата Госуслуг): GIGACHAT_VERIFY_SSL_CERTS=false

# === GenAPI / RockAPI / OpenAI-совместимые (если GIGACHAT_CREDENTIALS не задан) ===
GENAPI_API_KEY=your-key
GENAPI_BASE_URL=https://api.rockapi.ru/openai/v1
# GENAPI_MODEL=gpt-4o-mini

# === Telegram-бот ===
# Получить токен: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Опционально: уровень логирования (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
